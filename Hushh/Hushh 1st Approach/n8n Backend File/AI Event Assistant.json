    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\nconst results = [];\n\nfor (const item of allItems) {\n  let interests = item.json.Interests;\n\n  // Convert string array like '[\"Coding\",\"AI\"]'\n  if (typeof interests === \"string\" && interests.startsWith(\"[\")) {\n    try {\n      interests = JSON.parse(interests);\n    } catch {\n      interests = [interests];\n    }\n  }\n\n  // Convert comma-separated values\n  if (typeof interests === \"string\") {\n    interests = interests.split(\",\");\n  }\n\n  // Ensure array\n  if (!Array.isArray(interests)) {\n    interests = [interests];\n  }\n\n  // Create one output per interest\n  for (let interest of interests) {\n    results.push({\n      json: {\n        ...item.json,\n        Interests: interest.trim()\n      }\n    });\n  }\n}\n\nreturn results;"
      },
